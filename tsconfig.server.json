{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "outDir": "dist/server",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@server/*": ["./server/src/*"]
    },
    "noEmit": false
  },
  "include": ["server/src/**/*.ts", "server.ts"],
  "exclude": ["node_modules", "src"]
}
