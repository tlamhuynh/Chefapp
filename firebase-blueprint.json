{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["chef", "admin"] },
        "preferences": {
          "type": "object",
          "properties": {
            "chatUserBubbleColor": { "type": "string" },
            "chatAiBubbleColor": { "type": "string" },
            "chatBackground": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "Recipe details with costing and pricing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "theme": { "type": "string" },
        "ingredients": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "amount": { "type": "number" },
              "unit": { "type": "string" },
              "purchasePrice": { "type": "number" },
              "costPerAmount": { "type": "number" },
              "inventoryItemId": { "type": "string" }
            },
            "required": ["name", "amount", "unit"]
          }
        },
        "instructions": { "type": "string" },
        "totalCost": { "type": "number" },
        "recommendedPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "active", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "version": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["title", "authorId"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "Stock items in the kitchen",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "currentStock": { "type": "number" },
        "minStock": { "type": "number" },
        "unit": { "type": "string" },
        "lastPurchasePrice": { "type": "number" },
        "category": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" },
        "authorId": { "type": "string" }
      },
      "required": ["name", "currentStock", "unit", "authorId"]
    },
    "RecipeVersion": {
      "title": "RecipeVersion",
      "description": "Historical versions or experiments of a recipe",
      "type": "object",
      "properties": {
        "recipeId": { "type": "string" },
        "versionNumber": { "type": "number" },
        "changes": { "type": "string" },
        "ingredients": { "type": "array" },
        "instructions": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["recipeId", "versionNumber"]
    },
    "Order": {
      "title": "Order",
      "description": "Order analysis from photos",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "analysis": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["authorId"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Messages in the chef chat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "ai"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "conversationId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "error"] },
        "hasFiles": { "type": "boolean" },
        "fileNames": { "type": "array", "items": { "type": "string" } },
        "files": { "type": "array" },
        "suggestions": { "type": "array" },
        "recipe": { "type": "object" },
        "photos": { "type": "array" }
      },
      "required": ["text", "sender", "userId"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat conversation thread",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "userId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "Memory": {
      "title": "Memory",
      "description": "Long-term memory for the AI agent to learn from user interactions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "key": { "type": "string", "description": "The category or key of the memory (e.g., 'dietary_restrictions')" },
        "value": { "type": "string", "description": "The actual information remembered" },
        "importance": { "type": "number", "description": "How important this memory is (1-10)" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "key", "value"]
    },
    "SavedImage": {
      "title": "SavedImage",
      "description": "Images of dishes saved by the user from chat or other sources",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "filename": { "type": "string" },
        "title": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "description": "Where the image came from (e.g., 'chef_chat')" }
      },
      "required": ["url", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Agent long-term memory"
    },
    "/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Chef recipes"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order analysis"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Chat conversations"
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Chef chat history"
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Kitchen inventory"
    },
    "/recipe_versions/{versionId}": {
      "schema": "RecipeVersion",
      "description": "Recipe version history"
    },
    "/saved_images/{imageId}": {
      "schema": "SavedImage",
      "description": "User's saved dish images"
    }
  }
}
